# Server Configuration
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/hawkroute
# For MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hawkroute

# Redis Configuration
REDIS_URL=redis://localhost:6379
# For Redis Cloud:
# REDIS_URL=redis://username:password@hostname:port

# JWT Secret (Generate a strong random string)
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging
LOG_LEVEL=info

# Route Optimizer Service (Python microservice)
OPTIMIZER_SERVICE_URL=http://localhost:8000

# Real-time Update Intervals (milliseconds)
CONVOY_UPDATE_INTERVAL=5000
POSITION_BROADCAST_INTERVAL=3000

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
