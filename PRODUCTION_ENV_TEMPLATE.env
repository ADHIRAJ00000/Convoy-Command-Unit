# Production Environment Variables Template
# Copy this to your deployment platform's environment variables section

# ============================================
# BACKEND (Render) - Add these in Render Dashboard
# ============================================

# Required - Server Configuration
NODE_ENV=production
PORT=5000

# Required - Database (Get from MongoDB Atlas)
# 1. Go to https://cloud.mongodb.com
# 2. Click "Connect" on your cluster
# 3. Choose "Connect your application"
# 4. Copy connection string and replace <password>
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hawkroute

# Required - Security (Generate a new random one)
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_GENERATED_VALUE
JWT_EXPIRE=7d

# Required - CORS (Update after deploying frontend)
# Replace with your actual Vercel URL
CORS_ORIGINS=https://your-app.vercel.app,https://hawkroute-backend.onrender.com

# Optional - Redis (Skip if not using)
REDIS_URL=redis://localhost:6379

# Optional - Python Optimizer Service
# Deploy separately or disable by commenting out
OPTIMIZER_SERVICE_URL=https://hawkroute-optimizer.onrender.com

# Optional - Logging
LOG_LEVEL=info

# Optional - Simulation Settings
CONVOY_UPDATE_INTERVAL=5000
POSITION_BROADCAST_INTERVAL=3000

# Optional - Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100


# ============================================
# FRONTEND (Vercel) - Add these in Vercel Dashboard
# ============================================

# Required - Mapbox Token (Get from https://account.mapbox.com/access-tokens)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Required - Backend API URL (Update after deploying backend)
# Replace with your actual Render backend URL
NEXT_PUBLIC_API_URL=https://hawkroute-backend.onrender.com

# Optional - Weather Integration (Get from https://home.openweathermap.org/api_keys)
NEXT_PUBLIC_OPENWEATHER_API_KEY=your_openweather_api_key_here


# ============================================
# SETUP INSTRUCTIONS
# ============================================

# 1. MongoDB Atlas Setup:
#    - Create account at https://cloud.mongodb.com
#    - Create free cluster (M0)
#    - Create database user with password
#    - Whitelist IP: 0.0.0.0/0 (allow all for Render)
#    - Get connection string and update MONGODB_URI above

# 2. Mapbox Setup:
#    - Create account at https://mapbox.com
#    - Go to Account → Tokens
#    - Copy default public token
#    - Update NEXT_PUBLIC_MAPBOX_TOKEN above

# 3. OpenWeatherMap Setup (Optional):
#    - Create account at https://openweathermap.org
#    - Go to API keys section
#    - Copy your API key
#    - Update NEXT_PUBLIC_OPENWEATHER_API_KEY above

# 4. JWT Secret Generation:
#    - Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#    - Copy the output
#    - Update JWT_SECRET above

# 5. After Deployment:
#    - Deploy backend to Render first
#    - Copy the Render URL (e.g., https://hawkroute-backend.onrender.com)
#    - Update NEXT_PUBLIC_API_URL in Vercel with backend URL
#    - Update CORS_ORIGINS in Render with frontend URL
#    - Redeploy both services


# ============================================
# SECURITY NOTES
# ============================================
# - Never commit actual values to git
# - Use platform secret management (Render Env Vars, Vercel Env Vars)
# - Rotate JWT_SECRET periodically
# - Use strong passwords for MongoDB
# - Enable 2FA on all accounts (MongoDB, Mapbox, etc.)
# - Keep API keys secret (except NEXT_PUBLIC_* which are client-side by design)
